PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/chat_app
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
OTP_TTL_MINUTES=5
CLIENT_URL=http://localhost:4173,http://localhost:3000
ALLOW_IN_MEMORY_MONGO=true
PHONE_HASH_SECRET=change_this_to_a_different_long_random_secret
WEBSITE_URL=http://localhost:4173
APK_CHANNEL=production
APK_FILE_NAME=videoapp-release.apk
APK_DOWNLOAD_URL=
APK_CHECKSUM_SHA256=
APK_RELEASE_NOTES=OTP login with private contact matching
APK_VERSION=1.0.0
APK_BUILD_NUMBER=1
APK_MINIMUM_SUPPORTED_BUILD_NUMBER=1
DOWNLOAD_ADMIN_TOKEN=change_this_to_an_admin_publish_token
ENABLE_DEV_OTP_PREVIEW=false
