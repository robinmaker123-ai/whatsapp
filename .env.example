PORT=5173
NODE_ENV=development
MONGO_URI=mongodb://127.0.0.1:27017/chat_app
JWT_SECRET=replace_with_a_long_random_access_secret
REFRESH_TOKEN_SECRET=replace_with_a_long_random_refresh_secret
ADMIN_JWT_SECRET=replace_with_a_long_random_admin_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=30d
ADMIN_JWT_EXPIRES_IN=12h
OTP_TTL_MINUTES=5
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_REQUEST_COOLDOWN_SECONDS=45
CLIENT_URL=http://localhost:4173,http://localhost:5173,http://localhost:3000,http://localhost:8081
ALLOW_IN_MEMORY_MONGO=true
PHONE_HASH_SECRET=replace_with_a_different_long_random_secret
WEBSITE_URL=http://localhost:4173
WEBSITE_DOMAIN=
API_DOMAIN=
APK_CHANNEL=production
APK_FILE_NAME=videoapp-latest.apk
APK_DOWNLOAD_URL=
APK_CHECKSUM_SHA256=
APK_RELEASE_NOTES=OTP login with private contact matching
APK_VERSION=1.0.0
APK_BUILD_NUMBER=1
APK_MINIMUM_SUPPORTED_BUILD_NUMBER=1
DOWNLOAD_ADMIN_TOKEN=replace_with_a_release_publish_token
ENABLE_DEV_OTP_PREVIEW=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=12
UPLOAD_RATE_LIMIT_WINDOW_MS=600000
UPLOAD_RATE_LIMIT_MAX=30
ADMIN_RATE_LIMIT_WINDOW_MS=600000
ADMIN_RATE_LIMIT_MAX=40
UPLOAD_MAX_FILE_SIZE_BYTES=52428800
