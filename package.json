{
  "name": "videoapp-monorepo",
  "version": "1.0.0",
  "description": "VideoApp monorepo with website, mobile app, backend, and shared release assets",
  "main": "backend/src/server.js",
  "scripts": {
    "dev": "nodemon backend/src/server.js",
    "dev:backend": "nodemon backend/src/server.js",
    "start": "node backend/src/server.js",
    "dev:website": "npm run dev --prefix website",
    "dev:mobile": "npm run start --prefix mobile",
    "sync:shared-assets": "node scripts/sync-shared-assets.js",
    "build:website": "node scripts/sync-shared-assets.js && npm run build --prefix website",
    "build:docker": "docker build -t videoapp-api .",
    "typecheck:mobile": "npm run typecheck --prefix mobile",
    "release:android": "node scripts/publish-android-release.js",
    "admin:hash-password": "node scripts/generate-admin-password-hash.js",
    "test": "node --test \"tests/*.test.js\"",
    "test:realtime": "node --test tests/realtime-chat.test.js",
    "verify": "npm test && npm run typecheck:mobile && npm run build:website"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "chat"
  ],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.1.4",
    "mongoose": "^8.8.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "socket.io-client": "^4.8.1"
  }
}
