{
  "name": "videoapp-chat-backend",
  "version": "1.0.0",
  "description": "Node.js backend for a real-time chat application",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "dev:website": "npm run dev --prefix website",
    "build:website": "npm run build --prefix website",
    "typecheck:mobile": "npm run typecheck --prefix mobile",
    "seed:demo-users": "node scripts/seedDemoUsers.js",
    "test": "node --test \"tests/*.test.js\"",
    "test:realtime": "node --test tests/realtime-chat.test.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "mongoose",
    "jwt",
    "chat"
  ],
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.1.4",
    "mongoose": "^8.8.1",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "socket.io-client": "^4.8.1"
  }
}
