{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "validate:release-network": "node ./scripts/validate-release-network.mjs",
    "check:boolean-props": "node ./scripts/check-boolean-props.mjs",
    "doctor": "expo-doctor",
    "prebuild:android": "expo prebuild --platform android --no-install",
    "build:android:preview": "npm run validate:release-network && eas build -p android --profile preview",
    "build:android:apk": "npm run validate:release-network && eas build -p android --profile production",
    "build:android:aab": "npm run validate:release-network && eas build -p android --profile store"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "axios": "^1.14.0",
    "expo": "~54.0.33",
    "expo-application": "~7.0.8",
    "expo-av": "~16.0.8",
    "expo-contacts": "~15.0.11",
    "expo-document-picker": "~14.0.8",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-secure-store": "~15.0.7",
    "expo-status-bar": "~3.0.9",
    "js-sha256": "^0.11.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
